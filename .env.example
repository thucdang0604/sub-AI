# Sub-AI Environment Configuration
# Copy this file to .env and fill in your values

# AI Provider Keys (optional - leave blank for local-only mode)
OPENAI_API_KEY=
GEMINI_API_KEY=

# Local AI Model (default: qwen2.5-coder:1.5b via Ollama)
AI_MODEL=qwen2.5-coder:1.5b

# GitHub Personal Access Token (required for private repos & creating issues)
# Create at: https://github.com/settings/tokens → "Fine-grained tokens"
# Permissions needed: Contents (read), Issues (read/write), Pull requests (read)
GITHUB_TOKEN=
